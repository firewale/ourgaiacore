{
    "name": "OurGaiaExpress",
    "version": "0.0.1",
    "description": "Our Gaia on ExpressJS",
    "main": "dist/server.js",
    "type": "module",
    "author": "firewale",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "concurrently \"tsx src/server.ts\" \"vite\"",
        "build": "tsc -p tsconfig.server.json && vite build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc --noEmit -p tsconfig.frontend.json"
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "helmet": "^7.1.0",
        "ioredis": "^5.10.1",
        "morgan": "^1.10.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/google.maps": "^3.55.5",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.11.5",
        "@types/supertest": "^7.2.0",
        "@vitest/coverage-v8": "^1.2.2",
        "concurrently": "^8.2.2",
        "jsdom": "^24.0.0",
        "supertest": "^7.2.2",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3",
        "vite": "^5.0.12",
        "vitest": "^1.2.2"
    }
}
